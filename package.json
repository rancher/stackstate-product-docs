{
  "devDependencies": {
    "@antora/cli": "3.1.10",
    "@antora/site-generator": "3.1.10",
    "@asciidoctor/tabs": "1.0.0-beta.6",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "live-server": "^1.2.2"
  },
  "dependencies": {
    "@antora/lunr-extension": "1.0.0-alpha.8",
    "@sntke/antora-mermaid-extension": "0.0.6"
  },
  "scripts": {
    "build-dev": "antora --log-level=fatal ss-dev-playbook.yml",
    "build-dev-stackpacks2": "antora --log-level=fatal --attribute ss-ff-stackpacks2_enabled ss-dev-playbook.yml",
    "watch": "chokidar \"**/*.adoc\" \"**/antora.yml\" \"ss-dev-playbook.yml\" -c \"npm run build-dev\"",
    "watch-stackpacks2": "chokidar \"**/*.adoc\" \"**/antora.yml\" \"ss-dev-playbook.yml\" -c \"npm run build-dev-stackpacks2\"",
    "serve": "live-server build/site",
    "dev": "concurrently \"npm run watch\" \"npm run serve\"",
    "dev-stackpacks2": "concurrently \"npm run watch-stackpacks2\" \"npm run serve\""
  }
}
