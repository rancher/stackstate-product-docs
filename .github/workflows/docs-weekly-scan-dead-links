name: "Docs - Dead links scan full site"

on:
  schedule:
    # 5:00 AM IST is 23:30 UTC Sunday evening
    - cron: '30 23 * * 0'
  workflow_dispatch: # Allows you to manually trigger this from the Actions tab at any time

jobs:
  full-site-audit:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Run Full Site Link Checker
        uses: lycheeverse/lychee-action@v2.0.2
        with:
          # Checks all .adoc files in the repo, accepts 200-299 status codes, 
          # retries up to 3 times on flaky external sites.
          args: --verbose --no-progress --retry-wait-time 5 --max-retries 3 "**/*.adoc"
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}